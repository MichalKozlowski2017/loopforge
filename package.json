{
  "name": "loopforge",
  "private": true,
  "version": "0.0.0",
  "description": "Generator tras rowerowych dla Polski — Loopforge",
  "scripts": {
    "dev": "pnpm --filter @loopforge/web dev",
    "brouter": "bash infra/scripts/start-brouter.sh",
    "setup:brouter": "bash infra/scripts/setup-brouter.sh",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "db:push": "supabase db push",
    "db:push:local": "supabase db push --local",
    "setup:supabase": "bash infra/scripts/setup-supabase-env.sh",
    "import:osm": "bash infra/scripts/import-osm.sh",
    "import:osm:mazowsze": "bash infra/scripts/import-osm.sh mazowsze",
    "import:osm:warszawa": "bash infra/scripts/import-osm.sh warszawa",
    "apply:osm-rls": "node infra/scripts/apply-osm-rls.mjs",
    "build:ways": "node infra/scripts/run-sql.mjs infra/sql/build-ways.sql",
    "drop:osm": "node infra/scripts/run-sql.mjs infra/sql/drop-osm-tables.sql",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0"
}
